  cat > "$TMP_HOME/.codex/config.toml" << 'TOML'
[mcp_servers.icm]
command = "icm"
args = ["serve", "--compact"]
TOML

  run bash "$SCRIPTS_DIR/install.sh" --icm-only --hosts codex
  [ "$status" -eq 0 ]

  local header_count
  header_count=$(grep -cE '^\[mcp_servers\.icm\]' "$TMP_HOME/.codex/config.toml")
  [ "$header_count" -eq 1 ]
}

