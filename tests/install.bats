  [ -f "$TMP_HOME/.local/config/compat.json" ]

  run bash "$SCRIPTS_DIR/uninstall.sh" --force
  [ "$status" -eq 0 ]
  [ ! -f "$TMP_HOME/.local/config/compat.json" ]
}

