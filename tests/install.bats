  [ "$status" -eq 0 ]

  [ -f "$TMP_HOME/.local/bin/lib/docextract.py" ]
  [ -f "$TMP_HOME/.local/bin/lib/tdcache.py" ]
  [ -f "$TMP_HOME/.local/bin/lib/ctxwarn.py" ]
}

