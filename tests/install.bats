  local jsonl="$TMP_HOME/transcript.jsonl"
  python3 -c "import json; print(json.dumps({'content': 'short'}))" > "$jsonl"
  run "$TMP_HOME/.local/bin/token-diet" budget --check --transcript "$jsonl"
  [ "$status" -eq 0 ]
}

